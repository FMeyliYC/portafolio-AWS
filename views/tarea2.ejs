<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventario de Activos Cloud</title>
    <!-- Bootstrap para un diseño profesional rápido -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .hero-section { background: #232f3e; color: white; padding: 40px 0; margin-bottom: 30px; }
        .card-img-top { height: 200px; object-fit: cover; }
    </style>
</head>
<body>

<div class="hero-section text-center">
    <h1>Cloud Asset Management System</h1>
    <p>Ingeniería de Software con IA - Tarea 02</p>
</div>

<div class="container">
    <div class="row">
        <!-- Columna Formulario -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Registrar Nuevo Activo</h5>
                </div>
                <div class="card-body">
                    <form action="/registrar-tarea2" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">Nombre del Equipo</label>
                            <input type="text" name="nombre" class="form-control" placeholder="Ej: Laptop MacBook Pro" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categoría</label>
                            <select name="categoria" class="form-select">
                                <option value="Hardware">Hardware</option>
                                <option value="Networking">Networking</option>
                                <option value="Mobile">Mobile Devices</option>
                                <option value="Other">Otros</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea name="descripcion" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Imagen del Activo</label>
                            <input type="file" name="imagen" class="form-control" accept="image/*" required>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Subir a AWS</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Columna Lista de Activos -->
        <div class="col-md-8">
            <h3 class="mb-4">Equipos en Inventario (DynamoDB + S3)</h3>
            <div class="row">
                <% if (equipos.length === 0) { %>
                    <div class="alert alert-info">No hay equipos registrados aún.</div>
                <% } %>
                
                <% equipos.forEach(equipo => { %>
                    <div class="col-md-6 mb-4">
                        <div class="card h-100 shadow-sm">
                            <img src="<%= equipo.fotoUrl %>" class="card-img-top" alt="Imagen del activo">
                            <div class="card-body">
                                <h5 class="card-title"><%= equipo.nombre %></h5>
                                <span class="badge bg-secondary mb-2"><%= equipo.categoria %></span>
                                <p class="card-text text-muted"><%= equipo.descripcion %></p>
                            </div>
                            <div class="card-footer text-end text-muted" style="font-size: 0.8rem;">
                                ID: <%= equipo.id.substring(0,8) %>...
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<footer class="text-center mt-5 py-4 border-top">
    <p class="text-muted">Desarrollado para Seminario de Complementación Práctica VI</p>
</footer>

</body>
</html>